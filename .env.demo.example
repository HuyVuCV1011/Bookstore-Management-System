# Copy this file to .env.demo for local ngrok demos.
# Do not commit .env.demo.

POSTGRES_DB=bookstore
POSTGRES_USER=bookstore_user
POSTGRES_PASSWORD=demo-postgres-password
POSTGRES_PORT=5433

MONGODB_DB=bookstore
MONGODB_PORT=27018

REDIS_PORT=6380

NEO4J_USER=neo4j
NEO4J_PASSWORD=demo-neo4j-password
NEO4J_HTTP_PORT=7475
NEO4J_BOLT_PORT=7688

CASSANDRA_KEYSPACE=bookstore_events
CASSANDRA_DATACENTER=datacenter1
CASSANDRA_PORT=9044

# Local-only demo secret. Replace in your private .env.demo.
JWT_SECRET=demo-local-only-secret-demo-local-only-secret-256-bit-minimum

# Initial local values. Replace VITE_API_URL with the backend ngrok URL after the backend tunnel is created.
VITE_API_URL=http://localhost:8081/api

# Initial local values. Add the frontend ngrok origin after the frontend tunnel is created.
SECURITY_CORS_ALLOWED_ORIGINS=http://localhost:5174,http://localhost:5173
