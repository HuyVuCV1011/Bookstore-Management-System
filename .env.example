# Bookstore Management System - Environment Configuration Template
# Copy this file to '.env' and replace every dummy value for local development.
# Do not commit real .env files, passwords, JWT secrets, or production URLs.

# ------------------------------------------------------------------------------
# Backend Configuration
# ------------------------------------------------------------------------------
SERVER_PORT=8080
JWT_SECRET=replace-with-a-random-256-bit-base64-secret
JWT_ACCESS_TOKEN_EXPIRATION=900000
JWT_REFRESH_TOKEN_EXPIRATION=604800000
JWT_REFRESH_TOKEN_EXP_REMEMBER=2592000000

# ------------------------------------------------------------------------------
# 1. PostgreSQL (Relational Database)
# Holds transaction, user authentication, inventory, and book metadata.
# ------------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=bookstore
POSTGRES_USER=bookstore_user
POSTGRES_PASSWORD=change-me-postgres-password

# ------------------------------------------------------------------------------
# 2. MongoDB (Document Database)
# Holds user carts, wishlists, and book catalog reviews.
# ------------------------------------------------------------------------------
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_DB=bookstore
MONGODB_USER=
MONGODB_PASSWORD=
MONGO_EXPRESS_USERNAME=change-me-mongo-express-user
MONGO_EXPRESS_PASSWORD=change-me-mongo-express-password

# ------------------------------------------------------------------------------
# 3. Neo4j (Graph Database)
# Powers graph-based book recommendations and user interest networks.
# ------------------------------------------------------------------------------
NEO4J_HOST=localhost
NEO4J_PORT=7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me-neo4j-password

# ------------------------------------------------------------------------------
# 4. Cassandra (Wide-column Database)
# Stores real-time clickstream events, page views, and user sessions.
# ------------------------------------------------------------------------------
CASSANDRA_HOST=localhost
CASSANDRA_PORT=9042
CASSANDRA_KEYSPACE=bookstore
CASSANDRA_DATACENTER=datacenter1

# ------------------------------------------------------------------------------
# 5. Redis (In-Memory Key-Value Cache)
# Used for autocomplete cache, rate limiting, and temporary token blacklists.
# ------------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ------------------------------------------------------------------------------
# Frontend Configuration (Vite env variables)
# ------------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:8080/api
VITE_API_URL=http://localhost:8080/api
VITE_INACTIVITY_TIMEOUT=1800000
VITE_MOCK_ADMIN_EMAIL=admin@example.test
VITE_MOCK_ADMIN_PASSWORD=change-me-admin-password
VITE_MOCK_CUSTOMER_PASSWORD=change-me-customer-password

# ------------------------------------------------------------------------------
# Optional Local Demo Seed Values
# ------------------------------------------------------------------------------
ADMIN_EMAIL=admin@example.test
ADMIN_INITIAL_PASSWORD_HASH=replace-with-local-dev-bcrypt-hash
